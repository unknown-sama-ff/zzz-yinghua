# ============================================================
#  影画工坊 / Yinghua Workshop — server environment
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
#  Server-side keys: the frontend never sees these.
# ============================================================

# Port for the Node proxy (default 8787)
PORT=8787

# Allowed browser origin for CORS (the Vite dev server in development)
CORS_ORIGIN=http://localhost:5173

# --- Frontend: backend origin when frontend is deployed separately ---
# When the frontend is hosted on Vercel (static) and the Express proxy
# lives on Railway / another host, set this to the backend root URL
# so relative /api/* calls resolve correctly.
# Leave empty for dev (Vite proxies /api → localhost:8787).
VITE_API_BASE_URL=https://your-backend.up.railway.app

# --- Provider: seedream (image-to-image / image edit) ---
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://api.seedream.example/v1

# --- Provider: gpt-image (OpenAI gpt-image-1) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Vision model (face detection for viewer clip regions; gpt-4o-mini) ---
# Separate from the gpt-image key on purpose — no fallback between them.
# If empty and the frontend sends no key, /api/detect-face returns 401.
VISION_API_KEY=

# Outbound request timeout in ms (default 300000 — image-to-image can take minutes)
UPSTREAM_TIMEOUT_MS=300000
